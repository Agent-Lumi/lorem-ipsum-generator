<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Generate Lorem Ipsum text with multiple styles - classic, bacon ipsum, hipster, and corporate">
    <title>Lorem Ipsum Generator | Made by Lumi</title>
    <link rel="stylesheet" href="style.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📝</text></svg>">
</head>
<body>
    <div class="container">
        <header>
            <div class="logo"><span>📝</span></div>
            <h1>Lorem Ipsum Generator</h1>
            <p>Generate placeholder text with style</p>
        </header>
        
        <main>
            <div class="tool-box">
                <div class="controls">
                    <div class="control-group">
                        <label>Generate:</label>
                        <select id="type">
                            <option value="paragraphs">Paragraphs</option>
                            <option value="sentences">Sentences</option>
                            <option value="words">Words</option>
                        </select>
                    </div>
                    
                    <div class="control-group">
                        <label id="count-label">Number of Paragraphs:</label>
                        <input type="number" id="count" value="5" min="1" max="100">
                    </div>
                    
                    <div class="control-group">
                        <label>Style:</label>
                        <select id="style">
                            <option value="classic">📜 Classic Lorem</option>
                            <option value="bacon">🥓 Bacon Ipsum</option>
                            <option value="hipster">☕ Hipster Ipsum</option>
                            <option value="corporate">💼 Corporate Ipsum</option>
                        </select>
                    </div>
                    
                    <div class="control-group checkbox-group">
                        <label>
                            <input type="checkbox" id="html-tags">
                            Wrap paragraphs in &lt;p&gt; tags
                        </label>
                    </div>
                    
                    <button onclick="generate()" class="generate-btn">✨ Generate</button>
                </div>
                
                <div class="output-section">
                    <label>Generated Text:</label>
                    <div id="result" class="result"></div>
                    <div id="stats"></div>
                    <div class="actions">
                        <button onclick="copy()" class="copy-btn">📋 Copy to Clipboard</button>
                        <button onclick="clearAll()" class="secondary">🗑️ Clear</button>
                    </div>
                </div>
            </div>
        </main>
        
        <div class="history-section">
            <div class="history-header">
                <h3>📜 Recent Generations</h3>
                <button onclick="clearHistory()" class="clear-history-btn">Clear History</button>
            </div>
            <div id="history-list" class="history-list">
                <p class="history-empty">No recent generations yet. Generate some text to see it here!</p>
            </div>
        </div>
        
        <div class="favorites-section">
            <h3>⭐ Saved Presets</h3>
            <div id="favorites-list" class="favorites-list">
                <p class="favorites-empty">No saved presets. Click the ⭐ star button after generating to save a preset!</p>
            </div>
        </div>
        
        <footer>
            <p>Made with 💡 by <a href="https://github.com/Agent-Lumi" target="_blank">Lumi</a></p>
            <p><a href="https://github.com/Agent-Lumi/lorem-ipsum-generator" target="_blank">View on GitHub →</a></p>
        </footer>
    </div>
    
    <script src="app.js"></script>
    <script src="history.js"></script>
</body>
</html>
<script>
// Undo/Redo history
const history = { past: [], future: [] };
const saveState = () => {
    const state = document.querySelector('textarea, input')?.value;
    if (state) history.past.push(state);
};
document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'z') {
        e.preventDefault();
        if (e.shiftKey && history.future.length) {
            // Redo
            const state = history.future.pop();
            history.past.push(document.querySelector('textarea, input')?.value);
            if (document.querySelector('textarea, input')) document.querySelector('textarea, input').value = state;
        } else if (history.past.length) {
            // Undo
            const state = history.past.pop();
            history.future.push(document.querySelector('textarea, input')?.value);
            if (document.querySelector('textarea, input')) document.querySelector('textarea, input').value = state;
        }
    }
});
document.addEventListener('input', saveState);
</script>
<script>
// Dark mode toggle
const darkModeToggle = document.createElement('button');
darkModeToggle.textContent = '🌙';
darkModeToggle.style.cssText = 'position:fixed;top:20px;right:20px;background:none;border:none;font-size:24px;cursor:pointer;z-index:1000;';
darkModeToggle.onclick = () => {
    document.body.classList.toggle('dark-mode');
    darkModeToggle.textContent = document.body.classList.contains('dark-mode') ? '☀️' : '🌙';
    localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
};
document.body.appendChild(darkModeToggle);

// Check saved preference
if (localStorage.getItem('darkMode') === 'true') {
    document.body.classList.add('dark-mode');
    darkModeToggle.textContent = '☀️';
}
</script>
<style>
.dark-mode { background: #1a1a1a !important; color: #e0e0e0 !important; }
.dark-mode .container { background: #2a2a2a !important; }
</style>
<script>
// Keyboard shortcuts
document.addEventListener('keydown', (e) => {
    if (e.ctrlKey || e.metaKey) {
        switch(e.key) {
            case 's': e.preventDefault(); console.log('Save shortcut'); break;
            case 'r': e.preventDefault(); location.reload(); break;
            case 'f': e.preventDefault(); document.querySelector('input')?.focus(); break;
        }
    }
});
</script>
